<UserControl
    x:Class="WallpaperEngine.Views.FavoriteView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:WallpaperEngine.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:views="clr-namespace:WallpaperEngine.Views"
    xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
    x:Name="favoriteViewControl">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/WallpaperItemStyle.xaml" />
                <ResourceDictionary Source="/Converters/CommonConverters.xaml" />
                <ResourceDictionary Source="/Styles/FavoriteButtonStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <!--  壁纸网格  -->
        <ListBox
            x:Name="FavoriteWallpaperListBox"
            Grid.Column="0"
            HorizontalContentAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding FavoriteWallpapersView}"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.IsDeferredScrollingEnabled="False"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            SelectionMode="Single"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.ScrollUnit="Pixel"
            VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.Resources>
                <Style x:Key="SelectableBorderStyle" TargetType="Border">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="#E0E0E0" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Background" Value="#F0F8FF" />
                            <Setter Property="BorderBrush" Value="#2563eb" />
                            <Setter Property="BorderThickness" Value="4" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Resources>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <vwp:VirtualizingWrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border
                        Width="200"
                        Height="150"
                        Margin="5"
                        Cursor="Hand"
                        Style="{StaticResource SelectableBorderStyle}"
                        Tag="{Binding}">
                        <!--  右键菜单定义  -->
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem
                                    Command="{Binding DataContext.PreviewWallpaperCommand, Source={x:Reference favoriteViewControl}}"
                                    CommandParameter="{Binding}"
                                    Header="👁️ 预览壁纸" />
                                <Separator />
                                <MenuItem
                                    Command="{Binding DataContext.ApplyWallpaperCommand, Source={x:Reference favoriteViewControl}}"
                                    CommandParameter="{Binding}"
                                    Header="🚀 应用壁纸" />
                                <Separator />
                                <MenuItem
                                    Command="{Binding DataContext.ToggleFavoriteCommand, Source={x:Reference favoriteViewControl}}"
                                    CommandParameter="{Binding}"
                                    Header="{Binding IsFavorite, Converter={StaticResource FavoriteTextConverter}}" />
                                <Separator />
                                <MenuItem
                                    Command="{Binding DataContext.GoToWallpaperDirectoryCommand, Source={x:Reference favoriteViewControl}}"
                                    CommandParameter="{Binding}"
                                    Header="📁 转到壁纸目录" />
                                <Separator />
                                <MenuItem Header="📂 添加到合集">
                                    <MenuItem.ItemsSource>
                                        <Binding Path="DataContext.Collections" Source="{x:Reference favoriteViewControl}" />
                                    </MenuItem.ItemsSource>
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource CollectionMenuHeaderConverter}">
                                                        <Binding Path="PlacementTarget.Tag" RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                                        <Binding />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Command" Value="{Binding DataContext.AddToSpecificCollectionCommand, Source={x:Reference favoriteViewControl}}" />
                                            <Setter Property="CommandParameter">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource AddToCollectionConverter}">
                                                        <Binding Path="PlacementTarget.Tag" RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                                        <Binding Path="Id" />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Padding" Value="8,4" />
                                            <Setter Property="Margin" Value="0,2" />
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                    <MenuItem.Style>
                                        <Style BasedOn="{StaticResource {x:Type MenuItem}}" TargetType="MenuItem">
                                            <Setter Property="IsEnabled" Value="True" />
                                            <Setter Property="Header" Value="{Binding DataContext.Collections.Count, Source={x:Reference favoriteViewControl}, Converter={StaticResource CollectionCountConverter}}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.Collections.Count, Source={x:Reference favoriteViewControl}}" Value="0">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                                <MenuItem Header="🏷️ 添加到分类">
                                    <MenuItem.ItemsSource>
                                        <Binding Path="DataContext.MenuCategories" Source="{x:Reference favoriteViewControl}" />
                                    </MenuItem.ItemsSource>
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding Name}" />
                                            <Setter Property="Command" Value="{Binding DataContext.AddToSpecificCategoryCommand, Source={x:Reference favoriteViewControl}}" />
                                            <Setter Property="CommandParameter">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource AddToCategoryConverter}">
                                                        <Binding Path="PlacementTarget.Tag" RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                                        <Binding Path="Id" />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Padding" Value="8,4" />
                                            <Setter Property="Margin" Value="0,2" />
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                    <MenuItem.Style>
                                        <Style BasedOn="{StaticResource {x:Type MenuItem}}" TargetType="MenuItem">
                                            <Setter Property="IsEnabled" Value="True" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.MenuCategories.Count, Source={x:Reference favoriteViewControl}}" Value="0">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Setter Property="Header" Value="🏷️ 添加到分类（无可用分类）" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                                <Separator />
                                <MenuItem
                                    Command="{Binding DataContext.DeleteWallpaperCommand, Source={x:Reference favoriteViewControl}}"
                                    CommandParameter="{Binding}"
                                    Foreground="Red"
                                    Header="🗑️ 删除壁纸" />
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Border.InputBindings>
                            <MouseBinding
                                Command="{Binding DataContext.PreviewWallpaperCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Gesture="LeftDoubleClick" />
                        </Border.InputBindings>
                        <Grid>
                            <Image Source="{Binding PreviewImagePath, Converter={StaticResource ImageToSourceConverter}, IsAsync=True}" Stretch="UniformToFill" />
                            <Border VerticalAlignment="Bottom" Background="#80000000">
                                <TextBlock
                                    Margin="5"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Height="15"
                                    Text="{Binding Project.Title, Mode=TwoWay}"
                                    TextWrapping="Wrap" />
                            </Border>
                            <!--  收藏按钮 - 固定在右上角  -->
                            <Button
                                Margin="5"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource FavoriteButtonStyle}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <!--  详情面板  -->
        <Border
            Grid.Column="1"
            BorderBrush="#E0E0E0"
            BorderThickness="1,0,0,0">
            <views:WallpaperDetailView />
        </Border>
    </Grid>
</UserControl>
