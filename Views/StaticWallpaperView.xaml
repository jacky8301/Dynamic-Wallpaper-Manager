<UserControl
    x:Class="WallpaperEngine.Views.StaticWallpaperView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:WallpaperEngine.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
    x:Name="staticWallpaperViewControl">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/WallpaperItemStyle.xaml" />
                <ResourceDictionary Source="/Converters/CommonConverters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!--  左侧：工具栏 + 壁纸网格  -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  工具栏  -->
            <Border
                Grid.Row="0"
                Padding="8,6"
                Background="#FAFAFA"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Button
                        Padding="12,4"
                        Command="{Binding ImportImagesCommand}"
                        Content="📷 导入图片"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                    <Button
                        Margin="8,0,0,0"
                        Padding="12,4"
                        Command="{Binding ScanFolderCommand}"
                        Content="📂 扫描文件夹"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                    <TextBlock
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="Gray"
                        Text="{Binding WallpaperCount, StringFormat='共 {0} 张'}" />
                    <!--  搜索框  -->
                    <TextBox
                        Width="200"
                        Margin="16,0,0,0"
                        Padding="6,4"
                        VerticalAlignment="Center"
                        materialDesign:HintAssist.Hint="搜索文件名..."
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Border>

            <!--  壁纸网格  -->
            <ListBox
                x:Name="StaticWallpaperListBox"
                Grid.Row="1"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding StaticWallpapersView}"
                ScrollViewer.CanContentScroll="True"
                ScrollViewer.IsDeferredScrollingEnabled="False"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.ScrollUnit="Pixel"
                VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.Resources>
                    <Style x:Key="SelectableBorderStyle" TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="#E0E0E0" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="#F0F8FF" />
                                <Setter Property="BorderBrush" Value="#2563eb" />
                                <Setter Property="BorderThickness" Value="4" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Resources>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <vwp:VirtualizingWrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Width="200"
                            Height="150"
                            Margin="5"
                            Cursor="Hand"
                            Style="{StaticResource SelectableBorderStyle}"
                            Tag="{Binding}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem
                                        Command="{Binding DataContext.SetDesktopWallpaperCommand, Source={x:Reference staticWallpaperViewControl}}"
                                        CommandParameter="{Binding}"
                                        Header="🖼️ 设置为桌面壁纸" />
                                    <Separator />
                                    <MenuItem
                                        Command="{Binding DataContext.OpenFileLocationCommand, Source={x:Reference staticWallpaperViewControl}}"
                                        CommandParameter="{Binding}"
                                        Header="📁 打开文件位置" />
                                    <Separator />
                                    <MenuItem
                                        Command="{Binding DataContext.DeleteWallpaperCommand, Source={x:Reference staticWallpaperViewControl}}"
                                        CommandParameter="{Binding}"
                                        Foreground="Red"
                                        Header="🗑️ 从列表移除" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Image Source="{Binding FilePath, Converter={StaticResource ImageToSourceConverter}, IsAsync=True}" Stretch="UniformToFill" />
                                <Border VerticalAlignment="Bottom" Background="#80000000">
                                    <TextBlock
                                        Height="15"
                                        Margin="5"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding FileName}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!--  空状态提示  -->
            <TextBlock
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                Foreground="#999999"
                Text="点击「导入图片」或「扫描文件夹」添加静态壁纸">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WallpaperCount}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!--  右侧：预览面板  -->
        <Border
            Grid.Column="1"
            BorderBrush="#E0E0E0"
            BorderThickness="1,0,0,0">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  大图预览  -->
                <Border
                    Grid.Row="0"
                    Background="#F5F5F5"
                    CornerRadius="6">
                    <Image
                        Source="{Binding SelectedWallpaper.FilePath, Converter={StaticResource ImageToSourceConverter}, ConverterParameter=original}"
                        Stretch="Uniform" />
                </Border>

                <!--  信息区域  -->
                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedWallpaper}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Text="{Binding SelectedWallpaper.FileName}"
                        TextWrapping="Wrap" />
                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <TextBlock Foreground="Gray" Text="分辨率: " />
                        <TextBlock Text="{Binding SelectedWallpaper.Resolution}" />
                    </StackPanel>
                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                        <TextBlock Foreground="Gray" Text="文件大小: " />
                        <TextBlock Text="{Binding SelectedWallpaper.FormattedFileSize}" />
                    </StackPanel>
                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="Gray"
                            Text="显示方式: " />
                        <ComboBox
                            Width="120"
                            Margin="4,0,0,0"
                            Padding="8,4"
                            ItemsSource="{Binding FitModeOptions}"
                            SelectedValue="{Binding SelectedFitMode}"
                            SelectedValuePath="Value"
                            Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                    </StackPanel>
                </StackPanel>

                <!--  设置壁纸按钮  -->
                <Button
                    Grid.Row="2"
                    Height="36"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Stretch"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Command="{Binding SetDesktopWallpaperCommand}"
                    Content="🖼️ 设置为桌面壁纸">
                    <Button.Style>
                        <Style BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedWallpaper}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!--  未选中提示  -->
                <TextBlock
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="#999999"
                    Text="选择一张图片查看预览">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedWallpaper}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
